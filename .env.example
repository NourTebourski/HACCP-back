# App
NODE_ENV=production
PORT=3000

# Frontend URL (for CORS — set to your Vercel deployment URL)
FRONTEND_URL=https://your-app.vercel.app

# Database — on Render, DATABASE_URL is injected automatically from the linked PostgreSQL service
# For local dev, use individual vars below instead
# DATABASE_URL=postgres://user:password@host:5432/haccp_food

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-db-password
DB_DATABASE=haccp_food

# JWT — use strong random secrets in production
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me
JWT_REFRESH_EXPIRES_IN=7d

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100
